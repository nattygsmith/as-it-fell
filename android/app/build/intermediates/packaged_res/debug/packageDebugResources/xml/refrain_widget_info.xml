<?xml version="1.0" encoding="utf-8"?>
<!--
    Glance widget provider metadata.
    minWidth/minHeight correspond roughly to a 4×2 cell widget on a standard launcher.
    updatePeriodMillis is set to 0 because updates are driven by WorkManager, not
    the system's built-in update mechanism (which has a minimum of 30 minutes).
-->
<appwidget-provider
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:minWidth="250dp"
    android:minHeight="110dp"
    android:targetCellWidth="4"
    android:targetCellHeight="2"
    android:updatePeriodMillis="0"
    android:resizeMode="horizontal|vertical"
    android:widgetCategory="home_screen"
    android:initialLayout="@layout/glance_default_loading_layout" />
